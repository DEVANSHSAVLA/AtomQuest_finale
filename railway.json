{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["apps/api/**", "packages/shared-types/**"]
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm run start:prod --workspace=apps/api",
    "restartPolicyType": "ON_FAILURE"
  }
}
