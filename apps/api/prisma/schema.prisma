datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  displayName  String
  role         String        @default("AGENT")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]     @relation("CreatedSessions")
  participants Participant[]
  auditLogs    AuditLog[]
}

model TicketSequence {
  id      Int @id @default(1)
  current Int @default(0)
}

model CustomerProfile {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String
  company      String?
  phone        String?
  notes        String?
  slackUser    String?
  salesforceId String?
  hubspotId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WebhookEvent {
  id           String        @id @default(uuid())
  event        String
  payload      String
  attempts     Int           @default(0)
  status       String        @default("PENDING")
  responseCode Int?
  lastAttempt  DateTime?
  createdAt    DateTime      @default(now())
}

model IntegrationLog {
  id        String   @id @default(uuid())
  provider  String
  action    String
  status    String
  errorMsg  String?
  createdAt DateTime @default(now())
}

model WorkflowRule {
  id        String   @id @default(uuid())
  trigger   String
  action    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Session {
  id                 String             @id @default(uuid())
  ticketRef          String?            @unique
  category           String?
  severity           String             @default("MEDIUM")
  department         String?
  assignedAgentId    String?
  assignedTeam       String?
  title              String
  description        String?
  createdBy          String
  creator            User               @relation("CreatedSessions", fields: [createdBy], references: [id])
  status             String             @default("CREATED")
  startedAt          DateTime?
  endedAt            DateTime?
  agentNotes         String?
  resolutionStatus   String?
  feedbackRating     Int?
  feedbackResolved   Boolean?
  feedbackComments   String?
  sentiment          String             @default("NEUTRAL") // POSITIVE, NEUTRAL, NEGATIVE
  escalatedAt        DateTime?
  escalationReason   String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  invites            Invite[]
  messages           Message[]
  files              File[]
  recordings         Recording[]
  timeline           Timeline[]
  participants       Participant[]
  analytics          SessionAnalytics?
  summary            SessionSummary?
  auditLogs          AuditLog[]

  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
}

model Participant {
  id          String    @id @default(uuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName String
  email       String?
  role        String
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?
  isConnected Boolean   @default(true)

  @@index([sessionId])
  @@index([email])
}

model Invite {
  id           String        @id @default(uuid())
  sessionId    String
  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  token        String        @unique
  createdBy    String
  isUsed       Boolean       @default(false)
  isRevoked    Boolean       @default(false)
  usedAt       DateTime?
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  
  // Security Auditing Fields
  createdIp    String?
  usedIp       String?
  joinAttempts Int           @default(0)
}

model Message {
  id           String        @id @default(uuid())
  sessionId    String
  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId     String
  senderName   String
  senderRole   String
  content      String
  createdAt    DateTime      @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@index([sessionId, createdAt])
}

model File {
  id           String        @id @default(uuid())
  sessionId    String
  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  uploaderId   String
  uploaderName String
  originalName String
  storageKey   String
  mimeType     String
  sizeBytes    Int
  isScanned    Boolean       @default(false)
  isSafe       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  deletedAt    DateTime?

  @@index([sessionId])
  @@index([deletedAt])
}

model Recording {
  id              String          @id @default(uuid())
  sessionId       String
  session         Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  storageKey      String
  playbackUrl     String
  durationSeconds Int
  sizeBytes       Int
  status          String          @default("RECORDING")
  startedAt       DateTime        @default(now())
  endedAt         DateTime?
  createdAt       DateTime        @default(now())
  deletedAt       DateTime?

  @@index([sessionId])
  @@index([status])
  @@index([deletedAt])
}

model SessionAnalytics {
  id                 String   @id @default(uuid())
  sessionId          String   @unique
  session            Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  durationSec        Int      @default(0)
  totalMessages      Int      @default(0)
  totalFiles         Int      @default(0)
  recordingBytes     BigInt   @default(0)
  reconnectCount     Int      @default(0)
  averageRttMs       Float    @default(0.0)
  averagePacketLoss  Float    @default(0.0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SessionSummary {
  id            String   @id @default(uuid())
  sessionId     String   @unique
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  durationSec   Int
  participants  String   // JSON structure mapping participants: [{ name, role }, ...]
  totalMessages Int
  totalFiles    Int
  recordingUrl  String?
  endedBy       String   // Name or ID of the user who ended the call
  createdAt     DateTime @default(now())
}

model Timeline {
  id          String         @id @default(uuid())
  sessionId   String
  session     Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  event       String         // e.g. "Joined", "Recording Started", "Disconnected", "Reconnected"
  participant String         // Name/ID of participant triggering
  timestamp   DateTime       @default(now())

  @@index([sessionId, timestamp])
}

model AuditLog {
  id        String           @id @default(uuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  sessionId String?
  session   Session?         @relation(fields: [sessionId], references: [id])
  action    String
  payload   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}
