# SupportStream Backend - NestJS Environment Template
NODE_ENV=development
PORT=3001

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-neon-db-id.us-east-2.aws.neon.tech/supportstream?sslmode=require"

# Redis (Upstash Redis)
REDIS_URL="redis://default:token@upstash-redis-id.upstash.io:6379"

# Security Configurations
JWT_SECRET="super-secret-jwt-signing-key"

# TURN Server Settings (coturn)
TURN_HOST="turn.supportstream.xyz"
TURN_SECRET="my-coturn-shared-hmac-secret-key"

# Cloudflare R2 Storage Configurations
R2_ACCESS_KEY_ID="r2-access-key-id-here"
R2_SECRET_ACCESS_KEY="r2-secret-access-key-here"
R2_ENDPOINT="https://cloudflare-account-id.r2.cloudflarestorage.com"
R2_BUCKET="supportstream-assets"
R2_PUBLIC_URL="https://assets.supportstream.xyz"
